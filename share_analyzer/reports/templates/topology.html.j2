{% extends "_base.html.j2" %}
{% block body %}
  <p>Folder topology to depth {{ max_depth }}, sized by total bytes,
     coloured by dominant MIME category.</p>
  <div class="chart">{{ chart | safe }}</div>
  <h2>Folders ({{ rows | length }})</h2>
  <table>
    <thead>
      <tr>
        <th>Path</th><th class="num">Depth</th>
        <th class="num">Files</th><th class="num">Size</th>
        <th>Dominant MIME</th><th>Latest mtime</th>
      </tr>
    </thead>
    <tbody>
    {% for r in rows %}
      <tr>
        <td><code>{{ r.path }}</code></td>
        <td class="num">{{ r.depth }}</td>
        <td class="num">{{ '{:,}'.format(r.file_count) }}</td>
        <td class="num">{{ r.total_size | human_size }}</td>
        <td>{% if r.dominant_mime_category %}<span class="pill">{{ r.dominant_mime_category }}</span>{% endif %}</td>
        <td>{{ r.mtime_max or '' }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
{% endblock %}
