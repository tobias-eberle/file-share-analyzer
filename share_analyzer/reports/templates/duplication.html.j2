{% extends "_base.html.j2" %}
{% block body %}
  <p>Top duplicate clusters by wasted space (size × (count − 1)).
     Total wasted: <strong>{{ total_wasted | human_size }}</strong>
     across {{ rows | length }} clusters.</p>
  <table>
    <thead>
      <tr>
        <th>SHA-256</th>
        <th class="num">Copies</th>
        <th class="num">File size</th>
        <th class="num">Wasted</th>
        <th>Sample paths</th>
      </tr>
    </thead>
    <tbody>
      {% for r in rows %}
        <tr>
          <td><code>{{ r.sha256[:12] }}…</code></td>
          <td class="num">{{ r.file_count }}</td>
          <td class="num">{{ r.file_size | human_size }}</td>
          <td class="num">{{ r.wasted_bytes | human_size }}</td>
          <td>
            {% for p in r.sample_paths %}<div><code>{{ p }}</code></div>{% endfor %}
          </td>
        </tr>
      {% endfor %}
    </tbody>
  </table>
{% endblock %}
